{
    "rootpath": "..",
    "modules": [
        {
            "path": "base/Logger.zig",
            "ignore_all": true
        },
        {
            "path": "base/File.zig",
            "ignore": [
                "stat",
                "glob",
                "Writer",
                "FileList"
            ]
        },
        {
            "path": "base/Config.zig",
            "ignore_all": true
        },
        {
            "path": "base/Primitive.zig",
            "ignore": [
                "Value"
            ]
        },
        {
            "path": "base/Module.zig",
            "ignore": [
                "Module",
                "VTable"
            ]
        },
        {
            "path": "base/Function.zig",
            "ignore": [
                "Type",
                "Parameter"
            ]
        },
        {
            "path": "base/Node.zig",
            "ignore": [
                "ID",
                "iterChildren",
                "iterComponents",
                "visit",
                "collectInto",
                "setNameFormat",
                "Reader",
                "Writer"
            ]
        },
        {
            "path": "base/Component.zig",
            "ignore": [
                "Components",
                "VTable"
            ]
        },
        {
            "path": "base/Scene.zig"
        },
        {
            "path": "base/Signal.zig",
            "ignore": [
                "connect",
                "disconnect"
            ]
        },
        {
            "path": "base/Cart.zig",
            "ignore": [
                "FileSystem"
            ]
        },
        {
            "path": "base/Transform.zig"
        },
        {
            "path": "graphics/Window.zig"
        },
        {
            "path": "graphics/GPU.zig",
            "ignore_all": true
        },
        {
            "path": "input/Input.zig",
            "no_enum_prefix": [
                "Input"
            ] 
        },
        {
            "path": "input/InputMap.zig"
        },
        {
            "path": "graphics/Texture.zig",
            "ignore": [
                "addFromGltfImage",
                "syncGPU"
            ]
        },
        {
            "path": "graphics/Material.zig"
        },
        {
            "path": "graphics/Mesh.zig",
            "ignore": [
                "addFromGltfPrimitive",
                "syncGPU"
            ]
        },
        {
            "path": "graphics/Gltf.zig"
        },
        {
            "path": "graphics/Vertex.zig",
            "ignore": [
                "Layout"
            ]
        },
        {
            "path": "graphics/StaticMesh.zig"
        },
        {
            "path": "ui/Viewport.zig"
        },
        {
            "path": "ui/Font.zig"
        },
        {
            "path": "ui/Widget.zig",
            "ignore": [
                "renderWidget"
            ]
        },
        {
            "path": "ui/Button.zig"
        },
        {
            "path": "ui/Label.zig"
        },
        {
            "path": "lua/Lua.zig",
            "ignore_all": true
        }
    ]
}
